---
// @ts-ignore The docs app already uses this runtime package from Astro components.
import octicons from '@primer/octicons';
import {
	buildWorkshopFlow,
	workshopDefaults,
	workshopEntryPaths,
	workshopJourneys,
	workshopScenarioAdventures,
	workshopScenarios,
} from '../../lib/workshop/manifest';
import { workshopContent, workshopSource, type WorkshopContentEntry } from '../../generated/workshop-content.ts';

interface Props {
	org: string;
}

const { org } = Astro.props;

type WorkshopEntry = {
	id: string;
	journey: string;
	adventure: string;
	title: string;
	summary: string;
	body: string;
};

type WorkshopStep = {
	key: string;
	file: string;
	journey: string;
	adventure: string;
	title: string;
	summary: string;
	githubUrl: string;
	actions: string[];
	checks: string[];
	html: string;
};

type WorkshopMarkdownModule = {
	compiledContent: () => Promise<string>;
};

const workshopGithubBase = workshopSource.githubBaseUrl;
const workshopImageBase = workshopSource.rawBaseUrl;
const workshopLocalLinkPrefix = `/gh-aw/workshops/${org}/?__gh_aw_workshop_local__=`;
const workshopMarkdownModules = import.meta.glob('../../generated/workshop-markdown/*.md', { eager: true }) as Record<string, WorkshopMarkdownModule>;
const primerIcons = octicons as Record<string, { toSVG: (options: Record<string, string | number>) => string }>;

function iconSvg(name: string, size = 20) {
	const icon = primerIcons[name] ?? primerIcons.workflow;
	return icon.toSVG({ width: size, height: size, 'aria-hidden': 'true' });
}

function escapeHtml(value: string) {
	return value
		.replace(/&/gu, '&amp;')
		.replace(/</gu, '&lt;')
		.replace(/>/gu, '&gt;')
		.replace(/"/gu, '&quot;')
		.replace(/'/gu, '&#39;');
}

function safeJson(value: unknown): string {
	return JSON.stringify(value)
		.replace(/</gu, '\\u003c')
		.replace(/>/gu, '\\u003e')
		.replace(/&/gu, '\\u0026');
}

function resolveWorkshopAssetUrl(value: string) {
	if (/^(?:https?:|mailto:|#|\/)/u.test(value)) return value;
	if (value.startsWith('images/')) return new URL(value, workshopImageBase).toString();
	return '#';
}

function isLocalWorkshopStepLink(value: string) {
	return !/^(?:https?:|mailto:|#|\/)/u.test(value) && /\.md(?:#.*)?$/u.test(value);
}

function decodeLocalWorkshopStepLink(value: string) {
	if (value.startsWith(workshopLocalLinkPrefix)) {
		try {
			return decodeURIComponent(value.slice(workshopLocalLinkPrefix.length));
		} catch {
			return '';
		}
	}
	return isLocalWorkshopStepLink(value) ? value : '';
}

function firstSentence(value: string) {
	return value.match(/^.*?[.!?](?:\s|$)/u)?.[0].trim() ?? value.trim();
}

function sanitizeWorkshopHtml(html: string) {
	return html
		.replace(/<script\b[^>]*>[\s\S]*?<\/script>/giu, '')
		.replace(/<style\b[^>]*>[\s\S]*?<\/style>/giu, '')
		.replace(/<iframe\b[^>]*>[\s\S]*?<\/iframe>/giu, '')
		.replace(/\s+on[a-zA-Z]+\s*=\s*(?:"[^"]*"|'[^']*')/giu, '');
}

function transformTables(html: string) {
	return html.replace(/<table>([\s\S]*?)<\/table>/gu, (tableHtml) => {
		// Check if this is the entry path table by inspecting the <thead> cells.
		const theadMatch = tableHtml.match(/<thead>([\s\S]*?)<\/thead>/u);
		const thMatches = theadMatch ? [...theadMatch[1].matchAll(/<th(?:\s[^>]*)?>([\s\S]*?)<\/th>/gu)] : [];
		const normalizeHeader = (value: string) => value
			.replace(/<[^>]+>/gu, '')
			.replace(/[‘’]/gu, "'")
			.replace(/…/gu, '...')
			.replace(/\s+/gu, ' ')
			.trim();

		if (
			thMatches.length >= 3
			&& normalizeHeader(thMatches[0][1]) === "If you're a..."
			&& normalizeHeader(thMatches[1][1]) === 'Recommended setup adventure'
			&& normalizeHeader(thMatches[2][1]) === 'Why this path fits'
		) {
			const tbodyMatch = tableHtml.match(/<tbody>([\s\S]*?)<\/tbody>/u);
			const rows: [string, string, string][] = [];
			if (tbodyMatch) {
				for (const rowMatch of tbodyMatch[1].matchAll(/<tr>([\s\S]*?)<\/tr>/gu)) {
					const tdMatches = [...rowMatch[1].matchAll(/<td(?:\s[^>]*)?>([\s\S]*?)<\/td>/gu)];
					if (tdMatches.length >= 3) {
						rows.push([tdMatches[0][1].trim(), tdMatches[1][1].trim(), tdMatches[2][1].trim()]);
					}
				}
			}

			if (rows.length > 0) {
				const cards = rows.map(([audience, nextStep, fit]) => [
					'<article class="aw-workshop-entry-card">',
					'<p class="aw-workshop-entry-card-kicker">Entry path</p>',
					`<h4>${audience}</h4>`,
					`<p class="aw-workshop-entry-card-summary">${fit}</p>`,
					'<div class="aw-workshop-entry-card-next">',
					'<span>Recommended next step</span>',
					`<p>${nextStep}</p>`,
					'</div>',
					'</article>',
				].join(''));
				return `<section class="aw-workshop-entry-grid">${cards.join('')}</section>`;
			}
		}

		return `<div class="aw-workshop-table-wrap">${tableHtml}</div>`;
	});
}

function rewriteGfmAlerts(html: string) {
	// Pattern to detect a blockquote that opens with a GFM alert type marker.
	const openingPattern = /<blockquote>\s*<p>\[!(NOTE|TIP|WARNING|IMPORTANT|CAUTION)\]/giu;
	let result = '';
	let lastIndex = 0;
	let match: RegExpExecArray | null;

	while ((match = openingPattern.exec(html)) !== null) {
		const matchStart = match.index;
		const type = match[1];
		const afterTypeStart = matchStart + match[0].length;

		// Locate the matching </blockquote> by counting nesting depth so that
		// blockquotes nested inside the alert body are handled correctly.
		let depth = 1;
		let searchPos = afterTypeStart;
		let foundClose = -1;

		while (depth > 0 && searchPos < html.length) {
			const nextOpen = html.indexOf('<blockquote', searchPos);
			const nextClose = html.indexOf('</blockquote>', searchPos);

			if (nextClose === -1) break; // malformed HTML — leave as-is

			if (nextOpen !== -1 && nextOpen < nextClose) {
				depth++;
				searchPos = nextOpen + '<blockquote'.length;
			} else {
				depth--;
				if (depth === 0) {
					foundClose = nextClose;
					break;
				}
				searchPos = nextClose + '</blockquote>'.length;
			}
		}

		if (foundClose === -1) {
			// No matching close tag found; leave this blockquote untransformed.
			continue;
		}

		const blockquoteEnd = foundClose + '</blockquote>'.length;
		const afterType = html.slice(afterTypeStart, foundClose);

		const cls = `aw-workshop-admonition-${type.toLowerCase()}`;
		const title = type.charAt(0).toUpperCase() + type.slice(1).toLowerCase();
		let inner: string;
		if (afterType.startsWith('</p>')) {
			// [!TYPE]</p><p>rest...</p> — type was alone in first paragraph
			inner = afterType.slice(4).trim();
		} else {
			// [!TYPE]\ntext... — type and first line of content share a paragraph
			const newlineIndex = afterType.indexOf('\n');
			inner = newlineIndex >= 0 ? `<p>${afterType.slice(newlineIndex + 1)}` : afterType;
			inner = inner.trim();
		}

		result += html.slice(lastIndex, matchStart);
		result += `<aside class="${cls}"><p class="aw-workshop-admonition-title">${escapeHtml(title)}</p>${inner}</aside>`;
		lastIndex = blockquoteEnd;
		// Skip the regex past the entire consumed blockquote so it does not
		// re-match patterns that appear inside the body we just replaced.
		openingPattern.lastIndex = blockquoteEnd;
	}

	result += html.slice(lastIndex);
	return result;
}

function rewriteGfmTaskLists(html: string) {
	// Transform Astro/remark-gfm task list HTML into the workshop's styled checklist format.
	// remark-gfm outputs: <ul class="contains-task-list"> / <li class="task-list-item"><input ...> text</li>
	// Workshop expects: <ul class="aw-workshop-checklist"> / <li><label><input ...> text</label></li>
	let result = html.replace(/<ul\s+class="contains-task-list">/gu, '<ul class="aw-workshop-checklist">');
	result = result.replace(
		/<li\s+class="task-list-item">([\s\S]*?)<\/li>/gu,
		(_match, content) => `<li><label>${content.trim()}</label></li>`,
	);
	return result;
}

function rewriteWorkshopHtml(html: string) {
	return transformTables(rewriteGfmTaskLists(rewriteGfmAlerts(sanitizeWorkshopHtml(html)))

		.replace(/<(\/?)h([1-4])\b/gu, (_match, slash, level) => {
			return `<${slash}h${Math.min(Number(level) + 1, 4)}`;
		})
		.replace(/<a([^>]*?)href="([^"]+)"([^>]*)>/gu, (_match, beforeHref, href, afterHref) => {
			const localLink = decodeLocalWorkshopStepLink(href);
			if (localLink) {
				return `<a${beforeHref}href="#" data-workshop-local-link="${escapeHtml(localLink)}"${afterHref}>`;
			}
			return `<a${beforeHref}href="${escapeHtml(resolveWorkshopAssetUrl(href))}"${afterHref}>`;
		})
		.replace(/<img([^>]*?)src="([^"]+)"([^>]*)>/gu, (_match, beforeSrc, src, afterSrc) => {
			return `<img${beforeSrc}src="${escapeHtml(resolveWorkshopAssetUrl(src))}"${afterSrc}>`;
		}));
}

async function renderWorkshopHtml(entryId: string) {
	const moduleEntry = Object.entries(workshopMarkdownModules)
		.find(([path]) => path.endsWith(`/${entryId}`))
		?.[1];
	if (!moduleEntry) {
		throw new Error(`Missing generated workshop markdown for ${entryId}. Expected to find it in src/generated/workshop-markdown/.`);
	}
	let html = rewriteWorkshopHtml(await moduleEntry.compiledContent());
	if (entryId === '00-welcome.md') {
		html = html.replace(
			'I picked the row in the table above that best matches how I want to work today',
			'I picked the entry path above that best matches how I want to work today',
		);
	}
	return html;
}

function stripMarkdown(value: string) {
	return value
		.replace(/!\[([^\]]*)\]\([^)]+\)/gu, '$1')
		.replace(/\[([^\]]+)\]\([^)]+\)/gu, '$1')
		.replace(/`([^`]+)`/gu, '$1')
		.replace(/\*\*([^*]+)\*\*/gu, '$1')
		.replace(/_([^_]+)_/gu, '$1')
		.replace(/<[^>]+>/gu, '')
		.trim();
}

function uniqueItems(items: string[]) {
	const seen = new Set<string>();
	return items.filter((item) => {
		const normalized = item.toLowerCase();
		if (seen.has(normalized)) return false;
		seen.add(normalized);
		return true;
	});
}

function extractActionItems(markdown: string) {
	const lines = markdown.split('\n').map((line) => line.trim());
	const actions: string[] = [];
	let inCode = false;

	for (const line of lines) {
		if (line.startsWith('```')) {
			inCode = !inCode;
			continue;
		}
		if (inCode) continue;

		const action = line.match(/^\*\*Action:\*\*\s+(.+)$/u);
		if (action) actions.push(stripMarkdown(action[1]));

		const numbered = line.match(/^\d+\.\s+(.+)$/u);
		if (numbered) actions.push(stripMarkdown(numbered[1]));

		const checkbox = line.match(/^[*-] \[[ x]\]\s+(.+)$/iu);
		if (checkbox) actions.push(stripMarkdown(checkbox[1]));
	}

	return uniqueItems(actions)
		.filter((item) => item.length > 0 && item.length < 180)
		.slice(0, 4);
}

function extractCheckpointItems(markdown: string) {
	const checkpoint = markdown.match(/##\s+✅\s+Checkpoint[\s\S]*?(?=\n##\s+|\n#\s+|$)/u)?.[0] ?? markdown;
	const checks = checkpoint
		.split('\n')
		.map((line) => line.trim().match(/^[*-] \[[ x]\]\s+(.+)$/iu)?.[1])
		.filter((item): item is string => Boolean(item))
		.map(stripMarkdown);

	return uniqueItems(checks)
		.filter((item) => item.length > 0 && item.length < 180)
		.slice(0, 5);
}

function renderTutorialStep(step: WorkshopStep) {
	return step.html;
}

function normalizeKey(value: string) {
	return value.replace(/\.md$/u, '');
}

const workshopEntries: WorkshopEntry[] = workshopContent.map((entry: WorkshopContentEntry) => ({
	id: entry.id,
	journey: entry.journey,
	adventure: entry.adventure,
	title: entry.title,
	summary: entry.summary,
	body: entry.body,
}));

const workshopSteps: WorkshopStep[] = await Promise.all(workshopEntries.map(async (entry: WorkshopEntry) => {
	const key = normalizeKey(entry.id);

	return {
		key,
		file: `${key}.md`,
		journey: entry.journey,
		adventure: entry.adventure,
		title: entry.title,
		summary: entry.summary,
		githubUrl: new URL(`${key}.md`, workshopGithubBase).toString(),
		actions: extractActionItems(entry.body),
		checks: extractCheckpointItems(entry.body),
		html: await renderWorkshopHtml(entry.id),
	};
}));

const initialFlow = buildWorkshopFlow(workshopDefaults.journeyId, workshopDefaults.scenarioId);
const initialStepKey = initialFlow[0] ?? workshopSteps[0]?.key ?? '';
const initialStep = workshopSteps.find((item) => item.key === initialStepKey) ?? workshopSteps[0];
---

<section
	class="aw-workshop"
	data-workshop-root
	data-initial-step={initialStepKey}
>
	<div class="aw-workshop-setup" data-workshop-setup>
		<div class="aw-workshop-setup-step" data-workshop-setup-step="workspace">
			<section class="aw-workshop-picker">
				<div class="aw-workshop-picker-header">
					<p class="aw-workshop-picker-kicker">Entry path</p>
					<h3>How do you want to go through the workshop?</h3>
					<p class="aw-workshop-picker-help">Choose the route that matches the way you work. Each path starts fresh and switches to its authored step flow behind the scenes.</p>
				</div>
				<div class="aw-workshop-card-grid">
					{workshopEntryPaths.map((path) => {
						const journey = workshopJourneys.find((item) => item.id === path.journeyId) ?? workshopJourneys[0];
						return (
						<button
							type="button"
							class="aw-workshop-card"
							data-workshop-entry-path={path.id}
							data-workshop-journey={path.journeyId}
							style={`--aw-workshop-card-accent: ${journey.accent};`}
						>
							<span class="aw-workshop-card-icon" set:html={iconSvg(path.icon)} />
							<span class="aw-workshop-card-kicker">{path.kicker}</span>
							<span class="aw-workshop-card-route">{journey.label}</span>
							<strong class="aw-workshop-card-title">{path.label}</strong>
							<span class="aw-workshop-card-summary">{path.summary}</span>
							<small class="aw-workshop-card-fit">{path.fit}</small>
						</button>
						);
					})}
				</div>
			</section>
		</div>

		<div class="aw-workshop-setup-step" data-workshop-setup-step="scenario" hidden>
			<section class="aw-workshop-picker">
				<div class="aw-workshop-picker-header">
					<p class="aw-workshop-picker-kicker">Scenario</p>
					<h3>What do you want to automate?</h3>
				</div>
				<div class="aw-workshop-card-grid aw-workshop-card-grid-scenarios">
					{workshopScenarios.map((scenario) => (
						<button
							type="button"
							class="aw-workshop-card aw-workshop-card-scenario"
							data-workshop-scenario={scenario.id}
						>
							<span class="aw-workshop-card-icon" set:html={iconSvg(scenario.icon)} />
							<span class="aw-workshop-card-kicker">{scenario.kicker}</span>
							<strong class="aw-workshop-card-title">{scenario.label}</strong>
							<span class="aw-workshop-card-summary">{firstSentence(scenario.summary)}</span>
						</button>
					))}
				</div>
			</section>

			<section class="aw-workshop-tunnel-panel" data-workshop-tunnel-panel hidden>
				<div>
					<p class="aw-workshop-picker-kicker">VS Code</p>
					<h3>VS Code local path</h3>
					<p>
						This route follows the local setup path from the workshop content, but keeps you anchored in VS Code. If you prefer browser-based VS Code, you can still use Codespaces and follow the same terminal-style steps.
					</p>
				</div>
				<div class="aw-workshop-tunnel-actions">
					<a href="https://code.visualstudio.com/docs/sourcecontrol/overview" target="_blank" rel="noreferrer">VS Code git docs</a>
					<a href="https://docs.github.com/en/codespaces/overview" target="_blank" rel="noreferrer">Codespaces option</a>
				</div>
			</section>

			<div class="aw-workshop-setup-nav aw-workshop-setup-nav-start">
				<button type="button" class="aw-workshop-inline-button" data-workshop-setup-back>
					Back
				</button>
			</div>
		</div>
	</div>

	<section class="aw-workshop-flow" data-workshop-tutorial hidden>
		<div class="aw-workshop-flow-header">
			<div>
				<p class="aw-workshop-picker-kicker">Guided run</p>
				<h3 data-workshop-flow-title>Step map</h3>
			</div>
		</div>

		<div class="aw-workshop-panel-shell">
			<div class="aw-workshop-panel-header">
				<div class="aw-workshop-panel-heading">
					<p class="aw-workshop-panel-meta" data-workshop-step-position>Step 1</p>
					<p class="aw-workshop-panel-summary" data-workshop-step-summary>{initialStep?.summary ?? 'Start with the welcome step, then follow the path selected above.'}</p>
				</div>
				<div class="aw-workshop-panel-actions">
					<button type="button" class="aw-workshop-inline-button aw-workshop-inline-button-home" data-workshop-home>
						<span class="aw-workshop-button-icon" set:html={iconSvg('home', 16)} />
						<span>Home</span>
					</button>
					<button type="button" class="aw-workshop-inline-button aw-workshop-inline-button-subtle" data-workshop-change>
						Change route
					</button>
				</div>
			</div>

			<section class="aw-workshop-progress-card" aria-label="Workshop progress">
				<div class="aw-workshop-progress-overview">
					<div class="aw-workshop-progress-stat">
						<span data-workshop-lesson-percent>0%</span>
						<p>Complete</p>
					</div>
					<p class="aw-workshop-progress-context" data-workshop-lesson-context>Start with the welcome step, then follow the path selected above.</p>
				</div>
				<div class="aw-workshop-progress-timeline">
					<div class="aw-workshop-progress-track"><span data-workshop-lesson-bar style={`width: ${initialFlow.length ? '0%' : '100%'};`} /></div>
				</div>
			</section>

			<article class="aw-workshop-step-content sl-markdown-content" data-workshop-step-content set:html={initialStep ? renderTutorialStep(initialStep) : ''} />

			<div class="aw-workshop-panel-footer">
				<button type="button" class="aw-workshop-nav-button" data-workshop-prev>
					Previous step
				</button>
				<button type="button" class="aw-workshop-nav-button aw-workshop-nav-button-primary" data-workshop-next>
					Next step
				</button>
			</div>
		</div>
	</section>

	<script
		type="application/json"
		id="aw-workshop-step-data"
		set:html={safeJson(workshopSteps.map((step) => ({
			key: step.key,
			file: step.file,
			journey: step.journey,
			adventure: step.adventure,
			title: step.title,
			summary: step.summary,
			githubUrl: step.githubUrl,
			actions: step.actions,
			checks: step.checks,
			html: step.html,
		})))}
	/>
	<script
		type="application/json"
		id="aw-workshop-manifest"
		set:html={safeJson({
			defaults: workshopDefaults,
			entryPaths: workshopEntryPaths,
			journeys: workshopJourneys,
			scenarios: workshopScenarios,
			scenarioAdventures: workshopScenarioAdventures,
		})}
	/>
	<script is:inline>
		const root = document.querySelector('[data-workshop-root]');
		const stepDataNode = document.getElementById('aw-workshop-step-data');
		const manifestNode = document.getElementById('aw-workshop-manifest');

		if (root && stepDataNode && manifestNode) {
			const steps = JSON.parse(stepDataNode.textContent || '[]');
			const manifest = JSON.parse(manifestNode.textContent || '{}');
			const storageKey = 'gh-aw-docs-workshop-state';
			const storage = window.sessionStorage;
			const stepMap = new Map(steps.map((step) => [step.key, step]));
			const allStepKeys = steps.map((step) => step.key);
			const initialStep = root.getAttribute('data-initial-step') || steps[0]?.key || '';
			const defaultEntryPath = manifest.entryPaths.find((item) => item.journeyId === manifest.defaults.journeyId)
				|| manifest.entryPaths[0]
				|| { id: '', journeyId: manifest.defaults.journeyId };
			const createDefaultState = () => ({
				entryPathId: defaultEntryPath?.id,
				journeyId: defaultEntryPath?.journeyId || manifest.defaults.journeyId,
				scenarioId: '',
				stepKey: initialStep,
			});

			const buildFlow = (journeyId, scenarioId) => {
				const journey = manifest.journeys.find((item) => item.id === journeyId) || manifest.journeys[0];
				const contentJourneyIds = journey.contentJourneyIds || [];
				const scenarioAdventure = (manifest.scenarioAdventures || {})[scenarioId] || '';
				const isCopilot = contentJourneyIds.includes('copilot');

				const includedAdventures = new Set(['core', 'setup', 'advanced']);
				if (scenarioAdventure) includedAdventures.add(scenarioAdventure);
				if (isCopilot) includedAdventures.add('scenario-d');

				const candidates = steps.filter((step) => {
					if (isCopilot && step.journey === 'ui' && !['core', 'setup', 'advanced', 'scenario-d'].includes(step.adventure)) {
						return false;
					}
					const journeyMatch = step.journey === 'all' || contentJourneyIds.includes(step.journey);
					return journeyMatch && includedAdventures.has(step.adventure) && step.adventure !== 'side-quest';
				});

				const hubPrefixes = new Set(
					steps
						.filter((s) => contentJourneyIds.includes(s.journey))
						.map((s) => s.key.split('-')[0]),
				);

				return candidates
					.filter((step) => {
						if (step.journey !== 'all') return true;
						const keyPrefix = step.key.split('-')[0];
						// Case 1: exact prefix match (e.g. '11a' hub when '11a-build-*-ui' exists for this journey).
						if (hubPrefixes.has(keyPrefix)) return false;
						// Case 2: numeric-only prefix (e.g. '06'): hub if letter-variant specific entries exist ('06a', '06b').
						const numericOnly = keyPrefix.match(/^(\d+)$/);
						if (numericOnly) {
							const hubRe = new RegExp(`^${numericOnly[1]}[a-z]`);
							return ![...hubPrefixes].some((p) => hubRe.test(p));
						}
						return true;
					})
					.map((step) => step.key)
					.filter((stepKey) => stepKey !== 'README' && stepMap.has(stepKey));
			};

			const parseHash = () => {
				const hash = window.location.hash.slice(1);
				if (!hash) return { screen: 'setup-workspace', journeyId: null, scenarioId: null, stepKey: null };
				try {
					const params = new URLSearchParams(hash);
					const rawJourneyId = params.get('j');
					const rawScenarioId = params.get('s');
					const rawStepKey = params.get('t');
					// Validate each ID against the manifest before deriving the screen so that
					// an unknown journey/scenario cannot silently open a tutorial with stale state.
					const journeyId = rawJourneyId && manifest.journeys.find((j) => j.id === rawJourneyId) ? rawJourneyId : null;
					if (!journeyId) return { screen: 'setup-workspace', journeyId: null, scenarioId: null, stepKey: null };
					const scenarioId = rawScenarioId && manifest.scenarios.find((s) => s.id === rawScenarioId) ? rawScenarioId : null;
					if (!scenarioId) return { screen: 'setup-scenario', journeyId, scenarioId: null, stepKey: null };
					const stepKey = rawStepKey && stepMap.has(rawStepKey) ? rawStepKey : null;
					return { screen: 'tutorial', journeyId, scenarioId, stepKey };
				} catch {
					return { screen: 'setup-workspace', journeyId: null, scenarioId: null, stepKey: null };
				}
			};

			const buildHashUrl = (screen, journeyId, scenarioId, stepKey) => {
				const base = window.location.pathname + window.location.search;
				if (!journeyId || screen === 'setup-workspace') return base;
				if (screen === 'setup-scenario' || !scenarioId) return `${base}#j=${encodeURIComponent(journeyId)}`;
				if (!stepKey) return `${base}#j=${encodeURIComponent(journeyId)}&s=${encodeURIComponent(scenarioId)}`;
				return `${base}#j=${encodeURIComponent(journeyId)}&s=${encodeURIComponent(scenarioId)}&t=${encodeURIComponent(stepKey)}`;
			};

			const readState = () => {
				try {
					const parsed = JSON.parse(storage.getItem(storageKey) || '{}');
					const selectedEntryPath = manifest.entryPaths.find((item) => item.id === parsed.entryPathId)
						|| manifest.entryPaths.find((item) => item.journeyId === (parsed.journeyId || manifest.defaults.journeyId))
						|| defaultEntryPath;
					return {
						entryPathId: selectedEntryPath?.id || defaultEntryPath?.id,
						journeyId: parsed.journeyId || selectedEntryPath?.journeyId || manifest.defaults.journeyId,
						scenarioId: typeof parsed.scenarioId === 'string' ? parsed.scenarioId : '',
						stepKey: parsed.stepKey || initialStep,
					};
				} catch {
					return createDefaultState();
				}
			};

			const state = readState();

			// Override state from URL hash when present (hash takes precedence over localStorage).
			// parseHash validates all IDs against the manifest, so any non-null field is safe to apply.
			const hashOnLoad = parseHash();
			if (hashOnLoad.journeyId) {
				state.journeyId = hashOnLoad.journeyId;
				if (hashOnLoad.scenarioId) {
					state.scenarioId = hashOnLoad.scenarioId;
					if (hashOnLoad.stepKey) {
						state.stepKey = hashOnLoad.stepKey;
					}
				}
			}

			const saveState = () => {
				storage.setItem(storageKey, JSON.stringify(state));
			};

			const resetState = () => {
				Object.assign(state, createDefaultState());
				storage.removeItem(storageKey);
			};

			const track = (name, detail) => {
				window.dispatchEvent(new CustomEvent('gh-aw-workshop-analytics', { detail: { name, ...detail } }));
				if (typeof window.plausible === 'function') {
					window.plausible(name, { props: detail });
				}
			};

			const renderTutorialStep = (step) => {
				return step.html || '';
			};

			const calculateProgressPercent = (stepIndex, flowLength) => {
				if (stepIndex < 0) return 0;
				if (flowLength <= 1) return 100;
				return Math.round((stepIndex / (flowLength - 1)) * 100);
			};

			const setupScreen = root.querySelector('[data-workshop-setup]');
			const setupSteps = root.querySelectorAll('[data-workshop-setup-step]');
			const tutorialScreen = root.querySelector('[data-workshop-tutorial]');
			const tunnelPanel = root.querySelector('[data-workshop-tunnel-panel]');
			const flowTitle = root.querySelector('[data-workshop-flow-title]');
			const stepPosition = root.querySelector('[data-workshop-step-position]');
			const prevButton = root.querySelector('[data-workshop-prev]');
			const nextButton = root.querySelector('[data-workshop-next]');
			const stepBodyContainer = root.querySelector('[data-workshop-step-content]');
			const stepSummary = root.querySelector('[data-workshop-step-summary]');
			const lessonPercent = root.querySelector('[data-workshop-lesson-percent]');
			const lessonBar = root.querySelector('[data-workshop-lesson-bar]');
			const lessonContext = root.querySelector('[data-workshop-lesson-context]');
			let setupStep = 'workspace';

			const showSetupStep = (stepName, opts = {}) => {
				setupStep = stepName === 'scenario' ? 'scenario' : 'workspace';
				setupSteps.forEach((step) => {
					step.hidden = step.getAttribute('data-workshop-setup-step') !== setupStep;
				});
				render();
				if (opts.pushHistory !== false && setupStep === 'scenario') {
					history.pushState(null, '', buildHashUrl('setup-scenario', state.journeyId, null, null));
				}
			};

			const showSetup = (opts = {}) => {
				const shouldScroll = opts.scroll !== false;
				setupScreen.hidden = false;
				tutorialScreen.hidden = true;
				root.classList.remove('is-tutorial-active');
				showSetupStep('workspace', { pushHistory: false });
				if (opts.pushHistory !== false) {
					history.pushState(null, '', buildHashUrl('setup-workspace', null, null, null));
				}
				if (shouldScroll) {
					root.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			};

			const showTutorial = (opts = {}) => {
				ensureCurrentStepIsVisible();
				render();
				setupScreen.hidden = true;
				tutorialScreen.hidden = false;
				root.classList.add('is-tutorial-active');
				if (opts.pushHistory !== false) {
					history.pushState(null, '', buildHashUrl('tutorial', state.journeyId, state.scenarioId, state.stepKey));
				}
				root.scrollIntoView({ behavior: 'smooth', block: 'start' });
				track('Workshop Started', { journey: state.journeyId, scenario: state.scenarioId });
			};

			const getFlow = () => buildFlow(state.journeyId, state.scenarioId);

			const getFallbackStepKey = (flow = getFlow()) => {
				return flow[0] || initialStep || allStepKeys[0] || '';
			};

			// Applies valid fields from a parsed hash state object onto the mutable state.
			// Used by the popstate handler to synchronize state with the URL on back/forward navigation.
			// All IDs in parsed are pre-validated by parseHash; apply directly without re-checking.
			const applyHashState = (parsed) => {
				if (parsed.journeyId) {
					state.journeyId = parsed.journeyId;
				}
				if (parsed.scenarioId) {
					state.scenarioId = parsed.scenarioId;
				} else {
					// No valid scenario in the URL: clear scenario and reset step so the picker
					// shows no pre-selected value and forward-navigation restarts at the first step.
					state.scenarioId = '';
					state.stepKey = getFallbackStepKey();
				}
				if (parsed.stepKey) {
					state.stepKey = parsed.stepKey;
				}
			};

			const ensureCurrentStepIsVisible = () => {
				const flow = getFlow();
				if (!flow.includes(state.stepKey)) {
					state.stepKey = getFallbackStepKey(flow);
				}
			};

			const setCurrentStep = (stepKey, options = {}) => {
				if (typeof stepKey !== 'string' || !stepMap.has(stepKey)) return;
				state.stepKey = stepKey;
				saveState();
				render();
				if (options.pushHistory !== false && tutorialScreen && !tutorialScreen.hidden) {
					history.pushState(null, '', buildHashUrl('tutorial', state.journeyId, state.scenarioId, stepKey));
				}
				if (!options.silent) {
					track('Workshop Step Viewed', {
						journey: state.journeyId,
						scenario: state.scenarioId,
						step: stepKey,
					});
				}
			};

			const setJourney = (journeyId, entryPathId = state.entryPathId) => {
				if (typeof journeyId !== 'string') return;
				const journeyChanged = state.journeyId !== journeyId || state.entryPathId !== entryPathId;
				state.entryPathId = entryPathId;
				state.journeyId = journeyId;
				if (journeyChanged) {
					state.scenarioId = '';
					state.stepKey = getFallbackStepKey(buildFlow(journeyId, manifest.defaults.scenarioId));
				}
				ensureCurrentStepIsVisible();
				saveState();
				render();
				track('Workshop Journey Selected', { journey: journeyId, scenario: state.scenarioId });
			};

			const setScenario = (scenarioId) => {
				if (typeof scenarioId !== 'string') return;
				const scenarioChanged = state.scenarioId !== scenarioId;
				state.scenarioId = scenarioId;
				if (scenarioChanged) {
					state.stepKey = getFallbackStepKey(buildFlow(state.journeyId, scenarioId));
				}
				ensureCurrentStepIsVisible();
				saveState();
				render();
				track('Workshop Scenario Selected', { journey: state.journeyId, scenario: scenarioId });
			};

			const navigate = (direction) => {
				const flow = getFlow();
				if (flow.length === 0) return;
				const index = flow.indexOf(state.stepKey);
				const nextIndex = direction === 'next' ? index + 1 : index - 1;
				const target = flow[nextIndex];
				if (target) {
					setCurrentStep(target);
				} else {
					saveState();
					render();
				}
				root.scrollIntoView({ behavior: 'smooth', block: 'start' });
			};

			const render = () => {
				const flow = getFlow();
				const fallbackStepKey = getFallbackStepKey(flow);
				const activeStepKey = typeof state.stepKey === 'string' && stepMap.has(state.stepKey)
					? state.stepKey
					: fallbackStepKey;
				const activeStep = activeStepKey ? stepMap.get(activeStepKey) : undefined;
				if (!activeStep || !activeStepKey) {
					return;
				}

				state.stepKey = activeStepKey;
				const visibleFlow = flow.length > 0 ? flow : [activeStepKey];
				const journey = manifest.journeys.find((item) => item.id === state.journeyId) || manifest.journeys[0];
				const scenario = manifest.scenarios.find((item) => item.id === state.scenarioId) || manifest.scenarios[0];
				const stepIndex = visibleFlow.indexOf(activeStep.key);
				const progressPercent = calculateProgressPercent(stepIndex, visibleFlow.length);
				if (tunnelPanel) {
					tunnelPanel.hidden = state.journeyId !== 'vscode' || setupStep !== 'scenario';
				}
				lessonPercent.textContent = `${progressPercent}%`;
				lessonBar.style.width = `${progressPercent}%`;
				lessonContext.textContent = stepIndex >= 0
					? `${stepIndex + 1} of ${visibleFlow.length} in this ${journey.label} run.`
					: 'Linked step from the workshop source.';
				stepSummary.textContent = activeStep.summary || 'Follow the guided path for this lesson.';
				flowTitle.textContent = `${journey.label} x ${scenario.label}`;
				stepPosition.textContent = stepIndex >= 0 ? `Step ${stepIndex + 1} of ${visibleFlow.length}` : 'Linked step';
				stepBodyContainer.innerHTML = renderTutorialStep(activeStep);
				root.dataset.workshopFlowKeys = visibleFlow.join(',');
				root.dataset.workshopCurrentStep = activeStep.key;

				root.querySelectorAll('[data-workshop-entry-path]').forEach((button) => {
					const isActive = button.getAttribute('data-workshop-entry-path') === state.entryPathId;
					button.classList.toggle('is-active', isActive);
					button.setAttribute('aria-pressed', String(isActive));
				});

				root.querySelectorAll('[data-workshop-scenario]').forEach((button) => {
					const isActive = button.getAttribute('data-workshop-scenario') === state.scenarioId;
					button.classList.toggle('is-active', isActive);
					button.setAttribute('aria-pressed', String(isActive));
				});

				const flowIndex = visibleFlow.indexOf(activeStep.key);
				const isLastStep = flowIndex >= 0 && flowIndex >= visibleFlow.length - 1;
				prevButton.disabled = flowIndex <= 0;
				nextButton.disabled = flowIndex < 0;
				nextButton.textContent = isLastStep ? 'Finish workshop' : 'Next step';
			};

			root.addEventListener('click', (event) => {
				const target = event.target instanceof Element ? event.target.closest('button, a') : null;
				if (!target) return;

				if (target.matches('[data-workshop-change]')) {
					showSetup();
					return;
				}

				if (target.matches('[data-workshop-home]')) {
					resetState();
					render();
					showSetup();
					return;
				}

				if (target.matches('[data-workshop-entry-path]')) {
					setJourney(target.getAttribute('data-workshop-journey'), target.getAttribute('data-workshop-entry-path'));
					showSetupStep('scenario');
					root.scrollIntoView({ behavior: 'smooth', block: 'start' });
					return;
				}

				if (target.matches('[data-workshop-scenario]')) {
					setScenario(target.getAttribute('data-workshop-scenario'));
					showTutorial();
					return;
				}

				if (target.matches('[data-workshop-setup-back]')) {
					showSetupStep('workspace');
					root.scrollIntoView({ behavior: 'smooth', block: 'start' });
					return;
				}

				if (target.matches('[data-workshop-prev]')) {
					navigate('prev');
					return;
				}

				if (target.matches('[data-workshop-next]')) {
					navigate('next');
					return;
				}

				if (target.matches('[data-workshop-local-link]')) {
					event.preventDefault();
					const localHref = target.getAttribute('data-workshop-local-link') || '';
					const [filePart, anchorPart] = localHref.split('#');
					const stepKey = filePart.replace(/\.md$/u, '');
					setCurrentStep(stepKey);
					if (anchorPart) {
						requestAnimationFrame(() => {
							root.querySelector(`#${CSS.escape(anchorPart)}`)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
						});
						return;
					}
					root.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			});

			// Routes the UI to the screen described by a parsed hash state object,
			// without pushing a new history entry (used by popstate and initial load).
			const routeToScreen = (parsed, opts = {}) => {
				const scroll = opts.scroll !== false;
				if (parsed.screen === 'tutorial') {
					showTutorial({ pushHistory: false });
				} else if (parsed.screen === 'setup-scenario') {
					showSetup({ pushHistory: false, scroll });
					showSetupStep('scenario', { pushHistory: false });
				} else {
					showSetup({ pushHistory: false, scroll });
				}
			};

			window.addEventListener('popstate', () => {
				const parsed = parseHash();
				applyHashState(parsed);
				saveState();
				routeToScreen(parsed);
			});

			// Replace the initial history entry with the canonical URL derived from the effective
			// parsed state. This normalizes invalid or partial hashes (e.g. #j=unknown&s=unknown
			// becomes the plain path) so that back navigation works correctly.
			ensureCurrentStepIsVisible();
			history.replaceState(null, '', buildHashUrl(hashOnLoad.screen, hashOnLoad.journeyId, hashOnLoad.scenarioId, hashOnLoad.stepKey));
			routeToScreen(hashOnLoad, { scroll: false });
		}
	</script>
</section>

