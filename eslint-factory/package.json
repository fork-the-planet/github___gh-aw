{
  "name": "@github/gh-aw-eslint-factory",
  "version": "0.1.0",
  "private": true,
  "description": "Custom ESLint rule factory for gh-aw JavaScript runtime code",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint:setup-js": "npm run build && cd ../actions/setup/js && \"$INIT_CWD\"/node_modules/.bin/eslint --config \"$INIT_CWD\"/eslint.config.cjs .",
    "lint:setup-js:changed": "npm run build && cd ../actions/setup/js && \"$INIT_CWD\"/node_modules/.bin/eslint --config \"$INIT_CWD\"/eslint.config.cjs '*.cjs'",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.0.13",
    "@typescript-eslint/utils": "^8.46.2",
    "eslint": "^9.31.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9"
  }
}
